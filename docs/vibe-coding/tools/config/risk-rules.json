{
  "policyName": "strict-trigger-risk-rules",
  "version": "2026-07-17.001",
  "description": "Deterministic strict-trigger rules for startup planning and preflight checks. This policy is read-only and does not mutate repo state.",
  "failClosed": true,
  "maxChangedFilesLite": 5,
  "strictOnDelete": true,
  "strictOnRename": true,
  "keywordTriggers": [
    "auth",
    "login",
    "permission",
    "permissions",
    "role",
    "roles",
    "security",
    "secret",
    "secrets",
    "database",
    "db",
    "migration",
    "migrations",
    "schema",
    "deploy",
    "deployment",
    "stage",
    "production",
    "ci",
    "cd",
    "pipeline",
    "package",
    "dependency",
    "dependencies",
    "email",
    "confirmation",
    "delivery",
    "payment",
    "billing",
    "delete",
    "deletion",
    "public-api",
    "api",
    "route",
    "router",
    "admin",
    "harness",
    "shared-script",
    "session-start",
    "kit-update",
    "sync-forgpt",
    "cross-repo",
    "subtree",
    "vibe-coding"
  ],
  "pathPatternTriggers": [
    "**/auth/**",
    "**/login/**",
    "**/security/**",
    "**/secrets/**",
    "**/database/**",
    "**/db/**",
    "**/migration/**",
    "**/migrations/**",
    "**/schema/**",
    "**/deploy/**",
    "**/deployment/**",
    "**/.github/workflows/**",
    "**/ci/**",
    "**/cd/**",
    "**/api/**",
    "**/routes/**",
    "**/routing/**",
    "**/admin/**",
    "**/tests/harness/**",
    "**/test-harness/**",
    "tools/session-start.ps1",
    "tools/run-vibe.ps1",
    "tools/kit-update.ps1",
    "tools/sync-forgpt.ps1",
    "tools/publish-consumer-payload.ps1",
    "tools/git-helpers.ps1",
    "tools/packet-path-resolver.ps1",
    "tools/config/consumer-payload-policy.json",
    "tools/config/risk-rules.json",
    "protocol/**",
    "session-start-checklist.md",
    "QUICKSTART.md",
    "MIGRATION-INSTRUCTIONS.md",
    "portability/**"
  ],
  "sensitiveFileTriggers": [
    "package.json",
    "package-lock.json",
    "pnpm-lock.yaml",
    "yarn.lock",
    "requirements.txt",
    "pyproject.toml",
    "poetry.lock",
    "Pipfile",
    "Pipfile.lock",
    "go.mod",
    "go.sum",
    "Cargo.toml",
    "Cargo.lock",
    "pom.xml",
    "build.gradle",
    "build.gradle.kts",
    "settings.gradle",
    "global.json",
    "nuget.config",
    "Dockerfile",
    "docker-compose.yml",
    "docker-compose.yaml",
    ".env",
    ".env.local"
  ]
}
